---
import {
  type Project,
  projectName,
  projectDesc,
  linkLabel,
  linkA11yLabel,
  tagLabels,
} from '../data/projekty';
import type { Lang } from '../i18n/ui';

interface Props {
  project: Project;
  lang: Lang;
  /** Poziom nagłówka karty (h2 na liście, h3 na stronie głównej) */
  headingLevel?: 2 | 3;
}
const { project, lang, headingLevel = 3 } = Astro.props;
const Heading = `h${headingLevel}` as 'h2' | 'h3';
const name = projectName(project, lang);
const desc = projectDesc(project, lang);
---

<article class="card reveal">
  <div class="card-body">
    <Heading class="card-title">{name}</Heading>
    <p class="card-desc">{desc}</p>
    <ul class="card-tags" aria-hidden="true">
      {project.tags.map((tag) => <li class="tag">{tagLabels[tag][lang]}</li>)}
    </ul>
  </div>
  <div class="card-links">
    {
      project.links.map((link) => (
        <a
          class="card-link"
          href={link.href}
          rel="noopener"
          aria-label={linkA11yLabel(link, lang, name)}
        >
          <span aria-hidden="true">↗</span>
          <span aria-hidden="true">{linkLabel(link, lang)}</span>
        </a>
      ))
    }
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-2);
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-3);
    height: 100%;
    box-shadow: var(--shadow);
    transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease,
      box-shadow 0.2s ease;
  }
  .card:hover,
  .card:focus-within {
    border-color: var(--accent);
    background: var(--bg-elev-2);
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }
  .card-title {
    margin: 0 0 var(--space-1);
    font-size: 1.4rem;
  }
  .card-desc {
    margin: 0 0 var(--space-2);
    color: var(--text-muted);
    max-width: none;
  }
  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .card-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: var(--space-1);
  }
  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--accent);
    text-decoration: none;
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
  }
  .card-link:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }
</style>
